# BobShield AI Server Configuration

# Server Port
PORT=5000

# Node Environment (development, production, test)
NODE_ENV=development

# Maximum number of concurrent analysis sessions
MAX_SESSIONS=10

# Temporary repository storage path (relative to server directory)
TEMP_DIR=temp-repos

# Session timeout in milliseconds (default: 1 hour)
SESSION_TIMEOUT=3600000

# Enable detailed logging
DEBUG=false

# CORS allowed origins (comma-separated)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# GitHub Personal Access Token (optional, for private repos - future feature)
# GITHUB_TOKEN=your_github_token_here

# Maximum repository size in MB (default: 500MB)
MAX_REPO_SIZE=500

# Analysis timeout in milliseconds (default: 5 minutes)
ANALYSIS_TIMEOUT=300000